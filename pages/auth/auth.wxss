.auth-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(135deg, #5dc46b 0%, #1a4f20 100%);
  padding: 40rpx;
}

.auth-card {
  width: 100%;
  max-width: 600rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.auth-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.auth-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.auth-subtitle {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.auth-form {
  margin-bottom: 40rpx;
}

.auth-input {
  width: 100%;
  height: 100rpx;
  background: #f3fbf2;
  border: 2rpx solid #c8e6c9;
  border-radius: 12rpx;
  padding: 0 30rpx;
  font-size: 32rpx;
  box-sizing: border-box;
  transition: all 0.3s;
}

.auth-input:focus {
  border-color: #3fa34d;
  background: #fff;
}

.auth-input.error {
  border-color:rgb(4, 114, 28);
}

.error-text {
  display: block;
  color:rgb(0, 129, 58);
  font-size: 24rpx;
  margin-top: 16rpx;
  padding-left: 10rpx;
}

.auth-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #5dc46b 0%,rgb(79, 107, 82) 100%);
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 12rpx;
  margin-top: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.auth-btn::after {
  border: none;
}

.auth-btn[disabled] {
  opacity: 0.7;
}

.auth-footer {
  text-align: center;
  padding-top: 20rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #999;
}