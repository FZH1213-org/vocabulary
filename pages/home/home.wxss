/* 重置 page 样式 */
page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f7f1 0%, #ffffff 100%);
}

.home-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f7f1 0%, #ffffff 100%);
  padding: 30rpx;
  box-sizing: border-box;
}

/* 顶部信息栏 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #3fa34d 0%, #2d7a3a 100%);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(63, 163, 77, 0.3);
}

.header-content {
  flex: 1;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.header-icon {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-book {
  font-size: 60rpx;
}

/* 功能模块区域 */
.modules-section {
  padding: 0 10rpx;
}

.module-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 36rpx 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.module-card:active {
  transform: scale(0.98);
  box-shadow: 0 3rpx 12rpx rgba(0, 0, 0, 0.1);
}

.module-icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.module-card.learn .module-icon-wrapper {
  background: linear-gradient(135deg, #74c0fc 0%, #339af0 100%);
}

.module-card.story .module-icon-wrapper {
  background: linear-gradient(135deg, #ffa94d 0%, #fd7e14 100%);
}

.module-card.translate .module-icon-wrapper {
  background: linear-gradient(135deg, #69db7c 0%, #37b24d 100%);
}

.module-card.memory .module-icon-wrapper {
  background: linear-gradient(135deg, #da77f2 0%, #be4bdb 100%);
}

.module-emoji {
  font-size: 48rpx;
}

.module-content {
  flex: 1;
}

.module-name {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.module-desc {
  display: block;
  font-size: 26rpx;
  color: #888888;
}

.module-arrow {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow {
  font-size: 44rpx;
  color: #cccccc;
  font-weight: 300;
}

/* 底部提示 */
.footer {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.footer-text {
  font-size: 26rpx;
  color: #aaaaaa;
}